# Required unless you're routing through Bedrock/Vertex/Foundry.
ANTHROPIC_API_KEY=

# Optional: point at a repo other than the current directory.
PEJ_TARGET_CWD=.

# Optional: turn on the deep-research phase before planning.
# Comma-separated web pages, git repos, and local/remote documents (PDF, md, ...).
#PEJ_RESEARCH_SOURCES=https://example.com/spec,https://github.com/owner/repo,docs/design.pdf
# Comma-separated files of research you've already done; the phase builds on them.
#PEJ_RESEARCH_NOTES=notes/findings.md

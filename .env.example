# Used by the default Claude backend unless routing through Bedrock/Vertex/Foundry.
ANTHROPIC_API_KEY=

# Used by the Codex backend. An existing `codex login` session also works.
CODEX_API_KEY=

# Optional: point at a repo other than the current directory.
PEJ_TARGET_CWD=.

# Optional: choose the agent backend. Defaults to claude.
#PEJ_BACKEND=codex

# Optional: override the backend's default model and reasoning effort.
#PEJ_MODEL=gpt-5.6-sol
#PEJ_EFFORT=xhigh

# Optional: resume an interrupted run from .pej-state.json/PLAN.md.
#PEJ_RESUME=1

# Optional: run multiple independent research/planning agents.
#PEJ_RESEARCH_AGENTS=2
#PEJ_PLAN_AGENTS=3

# Optional: pause after the final plan is written and require human approval.
#PEJ_PLAN_APPROVAL=1

# Optional: turn on the deep-research phase before planning.
# Comma-separated web pages, git repos, and local/remote documents (PDF, md, ...).
#PEJ_RESEARCH_SOURCES=https://example.com/spec,https://github.com/owner/repo,docs/design.pdf
# Comma-separated files of research you've already done; the phase builds on them.
#PEJ_RESEARCH_NOTES=notes/findings.md
